# Enhancor API Configuration
# Get your API key from https://app.enhancor.ai/api-dashboard
ENHANCOR_API_KEY=your_api_key_here
ENHANCOR_API_URL=https://apireq.enhancor.ai/api/enhancor-ugc-full-access/v1

# Webhook URL for Enhancor callbacks (optional)
# If you expose localhost:8092 via ngrok or similar, set this to your public URL + /api/webhook
# Example: WEBHOOK_URL=https://your-tunnel.ngrok.io/api/webhook
# If not set, falls back to polling every 2 minutes
WEBHOOK_URL=

# Prompt Generation API (do not change unless self-hosting)
PROMPT_API_URL=https://gateway.sirioberati.com/.netlify/functions/generate-prompts

# Note: Image analysis is handled locally by Claude Code (no extra API key needed)
